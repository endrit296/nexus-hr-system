{
  "name": "nexus-time-tracking",
  "version": "1.0.0",
  "description": "Professional Payroll Module for Nexus HR",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testEnvironment node --forceExit",
    "test:coverage": "jest --testEnvironment node --forceExit --coverage"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 15000,
    "collectCoverageFrom": [
      "src/controllers/**/*.js",
      "src/routes/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80
      }
    }
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.15",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
