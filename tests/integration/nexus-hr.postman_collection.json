{
  "info": {
    "name": "Nexus HR System — Integration Tests",
    "_postman_id": "nexus-hr-integration-v1",
    "description": "Full integration test suite for the Nexus HR microservices platform. Run with Newman against a live stack.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId",       "value": "" },
    { "key": "employeeId",   "value": "" },
    { "key": "departmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Gateway is UP', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Service Registry",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/registry"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Registry returns service list', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('services');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Registration & Activation",
      "item": [
        {
          "name": "Register new user",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"newman_user\",\"email\":\"newman_{{$timestamp}}@nexus.test\",\"password\":\"Test1234!\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register returns 201 with message', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as admin",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@nexus.com\",\"password\":\"password123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login returns 200 with tokens', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.expect(body).to.have.property('refreshToken');",
                  "  pm.collectionVariables.set('accessToken',  body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "  if (body.user && body.user.id) {",
                  "    pm.collectionVariables.set('userId', body.user.id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get current user (me)",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('GET /me returns user', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('email');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh access token",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh returns new accessToken', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List users (admin)",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/auth/users?page=1&limit=5",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('List users returns paginated result', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('users');",
                  "  pm.expect(body.users).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot password",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@nexus.com\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Forgot password returns 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        {
          "name": "List departments",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/departments",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('List departments returns array', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create department",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/departments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Newman Test Dept\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create department returns 201', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.collectionVariables.set('departmentId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get department by ID",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/departments/{{departmentId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get department returns name', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.name).to.eql('Newman Test Dept');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "List employees (paginated)",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/employees?page=1&limit=5",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('List employees returns paginated result', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('employees');",
                  "  pm.expect(body).to.have.property('total');",
                  "  pm.expect(body).to.have.property('page');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create employee",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/employees",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\":\"Newman\",\"lastName\":\"Tester\",\"email\":\"newman.tester@nexus.test\",\"position\":\"QA Engineer\",\"hireDate\":\"2024-01-15\",\"salary\":60000,\"departmentId\":{{departmentId}}}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create employee returns 201', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.collectionVariables.set('employeeId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get employee by ID",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/employees/{{employeeId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get employee returns correct data', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.firstName).to.eql('Newman');",
                  "  pm.expect(body.lastName).to.eql('Tester');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update employee",
          "request": {
            "method": "PUT",
            "url":    "{{baseUrl}}/api/employees/{{employeeId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"position\":\"Senior QA Engineer\",\"salary\":75000}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Update employee returns updated position', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.position).to.eql('Senior QA Engineer');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Filter employees by status",
          "request": {
            "method": "GET",
            "url":    "{{baseUrl}}/api/employees?status=active&page=1&limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Filter by status returns active employees', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.employees).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete employee",
          "request": {
            "method": "DELETE",
            "url":    "{{baseUrl}}/api/employees/{{employeeId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delete employee returns 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Payroll",
      "item": [
        {
          "name": "Calculate salary",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/payroll/calculate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"employeeName\":\"Newman Tester\",\"role\":\"QA Engineer\",\"hourlyRate\":30,\"hoursWorked\":160}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Payroll calculation returns VERIFIED', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('VERIFIED');",
                  "  pm.expect(body).to.have.property('financial_summary');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Logout",
      "item": [
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url":    "{{baseUrl}}/api/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout returns 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
