{
  "id": null,
  "uid": "nexus-hr-overview",
  "title": "Nexus HR — API Gateway Overview",
  "tags": ["nexus-hr"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (last 5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(nexus_http_requests_total[5m]))",
          "legendFormat": "Requests"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (last 5m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(nexus_http_requests_total{status_code=~'5..'}[5m])) / sum(increase(nexus_http_requests_total[5m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Response Time",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "unit": "s",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1 }
          ]
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(nexus_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Gateway Uptime",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "unit": "s" },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nexus_process_uptime_seconds",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (req/s by route)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (route) (rate(nexus_http_requests_total[1m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Response Time Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(nexus_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(nexus_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(nexus_http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (status_code) (rate(nexus_http_requests_total[1m]))",
          "legendFormat": "HTTP {{status_code}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nexus_process_resident_memory_bytes",
          "legendFormat": "RSS Memory"
        },
        {
          "datasource": "Prometheus",
          "expr": "nexus_nodejs_heap_size_used_bytes",
          "legendFormat": "Heap Used"
        }
      ]
    }
  ]
}
