# Copy to .env and fill in real values before deploying to production.
# docker-compose.yml reads these via ${VAR_NAME} substitution.

JWT_SECRET=replace_with_a_long_random_secret
DB_PASS=replace_with_strong_password
POSTGRES_PASSWORD=replace_with_strong_password

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail example: create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account)
APP_URL=http://localhost
FROM_EMAIL=your@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
